MW_QUEUE_BACKEND=memory
MW_RUN_WORKERS_INLINE=false
MW_REDIS_URL=redis://localhost:6379/0
MW_DATABASE_URL=sqlite+aiosqlite:///./media_watch.db
MW_STORAGE_BACKEND=local
MW_STORAGE_DIR=./buffer
MW_MAX_UPLOAD_BYTES=524288000
MW_ENABLED_PIPELINES=

MW_MODELS_ENABLED=false
MW_MODEL_DEVICE=cpu
MW_ALLOW_MODEL_DOWNLOADS=false
MW_WHISPER_MODEL=base
MW_CLIP_MODEL=openai/clip-vit-base-patch32
MW_EMBEDDING_BACKEND=hybrid
MW_OCR_BACKEND=auto
MW_TRANSCRIPTS_DIR=./output/transcripts

# Per-platform cap (seconds) on how long the bot records a single video before
# sending the partial clip; 0 = no cap. Overridable per-request from the UI.
MW_PARSER_MAX_VIDEO_SECONDS_INSTAGRAM=0
MW_PARSER_MAX_VIDEO_SECONDS_TIKTOK=0

# OpenRouter LLM summary for flagged reels (leave key empty to disable).
MW_OPENROUTER_API_KEY=
MW_OPENROUTER_MODEL=google/gemini-2.0-flash-001
MW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MW_OPENROUTER_TIMEOUT_SECONDS=30
