MW_QUEUE_BACKEND=memory
MW_RUN_WORKERS_INLINE=false
MW_REDIS_URL=redis://localhost:6379/0
MW_DATABASE_URL=sqlite+aiosqlite:///./media_watch.db
MW_STORAGE_BACKEND=local
MW_STORAGE_DIR=./buffer
MW_MAX_UPLOAD_BYTES=524288000
MW_ENABLED_PIPELINES=

MW_MODELS_ENABLED=false
MW_MODEL_DEVICE=cpu
MW_ALLOW_MODEL_DOWNLOADS=false
MW_WHISPER_MODEL=base
MW_CLIP_MODEL=openai/clip-vit-base-patch32
MW_EMBEDDING_BACKEND=tfidf
MW_OCR_BACKEND=auto
MW_TRANSCRIPTS_DIR=./output/transcripts
