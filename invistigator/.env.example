# Бёрнер-аккаунт Instagram (логин только через scripts/login.py)
IG_USERNAME=your_burner_login
IG_PASSWORD=your_burner_password
IG_2FA_SECRET=         # TOTP base32-ключ из формата выдачи аккаунта (если есть 2FA)
IG_SESSION_FILE=invistigator_session

# Анти-бан: паузы между профилями и потолок в час
MIN_DELAY_SEC=8
MAX_DELAY_SEC=20
MAX_PROFILES_PER_HOUR=120

# Прокси (для купленных аккаунтов почти обязателен). Формат: scheme://user:pass@host:port
# HTTP_PROXY=socks5://user:pass@host:port

# Соседний telegramcrawler
CRAWLER_URL=http://localhost:8000

# Хранилище
CSV_PATH=results.csv
MEDIA_DIR=media
